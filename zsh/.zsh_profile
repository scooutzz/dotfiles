# Some path exports
export XDG_CONFIG_HOME=$HOME/.config
export EDITOR=nvim
export VISUAL=nvim
export TERMINAL=kitty

# Neovim
alias vim='nvim'

# Smarter cd
alias cd='z'
alias cat='bat'

# Better ls
alias ls='eza -lh --group-directories-first --icons=auto'
alias lsa='ls -a'
alias lt='eza --tree --level=2 --long --icons --git'
alias lta='lt -a'

# File system
alias ff="fzf --preview 'bat --style=numbers --color=always {}'"
